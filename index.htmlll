<!DOCTYPE html>
<html lang="hi">
<head>
<meta charset="UTF-8">
<title>News Bulletin Generator</title>
<style>
    @import url('https://fonts.googleapis.com/css2?family=Hind:wght@500;600;700&family=Mukta:wght@700;800;900&family=Poppins:wght@600;700;800&display=swap');

    * { margin:0; padding:0; box-sizing:border-box; }

    body{
        font-family:'Hind',sans-serif;
        background:#eee6d4;
        display:flex;
        min-height:100vh;
    }

    /* ============ LEFT: EDITOR PANEL ============ */
    .editor{
        width:400px; flex-shrink:0;
        background:#211c15; color:#f3ead9;
        padding:22px 20px; overflow-y:auto;
        height:100vh; position:sticky; top:0;
    }
    .editor h1{ font-family:'Poppins',sans-serif; font-size:18px; margin-bottom:4px; }
    .editor .sub{ font-size:12px; color:#c99a3d; margin-bottom:16px; }
    .editor label{ font-size:12px; font-weight:700; color:#d9772a; display:block; margin:14px 0 6px; text-transform:uppercase; letter-spacing:1px; }
    .editor input[type=text]{
        width:100%; padding:9px 10px; border-radius:6px; border:none;
        background:#37301f; color:#fffaf0; font-family:'Hind',sans-serif; font-size:14px;
    }
    .editor textarea{
        width:100%; height:360px; padding:12px; border-radius:8px; border:none;
        background:#37301f; color:#fffaf0; font-family:'Hind',sans-serif; font-size:14px;
        line-height:1.6; resize:vertical;
    }
    .editor .help{
        margin-top:14px; font-size:12px; line-height:1.7; color:#c9bfa5;
        background:#2b2519; padding:12px 14px; border-radius:8px; border-left:3px solid #d9772a;
    }
    .editor .help b{ color:#f3ead9; }
    .editor .warn{
        margin-top:10px; font-size:11.5px; line-height:1.6; color:#f0c48a;
        background:#3a2412; padding:10px 12px; border-radius:8px; border-left:3px solid #d9772a;
    }
    .zoom-status{ margin-top:10px; font-size:12px; color:#c99a3d; font-weight:700; }
    .btn-row{ display:flex; gap:10px; margin-top:18px; }
    .btn{ flex:1; padding:11px 8px; border:none; border-radius:8px; font-family:'Poppins',sans-serif; font-weight:700; font-size:13px; cursor:pointer; }
    .btn.primary{ background:#d9772a; color:#fff; }
    .btn.secondary{ background:#3a3221; color:#f3ead9; border:1px solid #55492e; }
    .btn:hover{ filter:brightness(1.08); }

    /* ============ RIGHT: PREVIEW ============ */
    .preview-wrap{ flex:1; display:flex; justify-content:center; align-items:flex-start; padding:40px 20px; overflow-y:auto; height:100vh; }

    /* Fixed A4-ish frame with a small safety buffer so stray printer margins
       never push content onto a second blank page */
    .page-frame{
        width:210mm;
        height:292mm;
        background:
            radial-gradient(circle at 15% 12%, rgba(255,255,255,0.5), transparent 45%),
            #fffaf0;
        position:relative;
        border-radius:6px;
        box-shadow:
            0 30px 70px rgba(60,30,10,0.32),
            0 2px 0 rgba(255,255,255,0.4) inset;
        overflow:hidden;
        flex-shrink:0;
    }
    .page-frame::before{
        content:"";
        position:absolute; inset:14px;
        border:2px solid #b85c1a;
        border-radius:4px;
        pointer-events:none;
        z-index:2;
    }

    .page{
        width:100%;
        height:100%;
        padding:58px 52px 50px;
        display:flex;
        flex-direction:column;
        position:relative;
        z-index:1;
        font-feature-settings: "kern" 1, "liga" 1;
    }

    /* ---------- 3D brass corner-guard ornaments ---------- */
    .corner{
        position:absolute;
        width:70px; height:70px;
        z-index:3;
        filter: drop-shadow(0 3px 4px rgba(90,45,10,0.35));
    }
    .corner.tl{ top:18px; left:18px; }
    .corner.tr{ top:18px; right:18px; transform:scaleX(-1); }
    .corner.bl{ bottom:18px; left:18px; transform:scaleY(-1); }
    .corner.br{ bottom:18px; right:18px; transform:scale(-1,-1); }

    /* ---------- Header ---------- */
    .header{
        position:relative; z-index:5;
        text-align:center;
        padding-bottom:22px;
        margin-bottom:36px;
    }
    .main-title{
        font-family:'Mukta',sans-serif;
        font-size:64px;
        font-weight:900;
        color:#1f1d18;
        letter-spacing:-1px;
        text-shadow: 0 1px 0 rgba(255,255,255,0.6), 0 2px 3px rgba(140,74,31,0.15);
    }
    .subtitle{
        font-family:'Poppins',sans-serif;
        font-size:22px;
        font-weight:900;
        color:#b85c1a;
        letter-spacing:5px;
        margin-top:10px;
    }
    .header-rule{
        display:flex; align-items:center; justify-content:center; gap:14px;
        margin-top:20px;
    }
    .header-rule .bar{
        flex:1; max-width:280px; height:3px; border-radius:3px;
        background:linear-gradient(90deg, transparent, #d9772a, transparent);
    }
    .header-rule .seal{
        width:16px; height:16px; border-radius:50%;
        background:radial-gradient(circle at 35% 30%, #f2b25a, #b85c1a 70%);
        box-shadow:0 2px 4px rgba(140,74,31,0.4), inset 0 1px 1px rgba(255,255,255,0.5);
        flex-shrink:0;
    }

    /* ---------- Section plaque ---------- */
    .section-title{
        position:relative; z-index:5;
        font-family:'Mukta',sans-serif;
        font-size:31px;
        font-weight:900;
        color:#1f1d18;
        padding:16px 32px;
        background:linear-gradient(180deg, #fbf5e6, #ecdcb5);
        border-radius:10px;
        margin:36px 0 24px;
        box-shadow:
            0 10px 22px rgba(140,74,31,0.22),
            inset 0 1px 0 rgba(255,255,255,0.7),
            inset 0 -14px 18px -14px rgba(140,74,31,0.18);
        display:flex; align-items:center; gap:16px;
    }
    .section-title::before{
        content:"";
        width:9px; align-self:stretch; border-radius:5px;
        background:linear-gradient(180deg, #e08a3e, #a63d2c);
        box-shadow:0 2px 5px rgba(140,74,31,0.4);
        flex-shrink:0;
    }

    /* ---------- News cards ---------- */
    .news-item{
        position:relative; z-index:5;
        background:linear-gradient(180deg,#ffffff,#fffdf7);
        padding:22px 30px;
        margin-bottom:22px;
        border-radius:14px;
        box-shadow:
            0 14px 30px rgba(184,92,26,0.18),
            0 2px 6px rgba(140,74,31,0.12),
            inset 0 1px 0 rgba(255,255,255,0.9);
    }
    .news-item::before{
        content:"";
        position:absolute; left:0; top:10px; bottom:10px; width:6px;
        border-radius:4px;
        background:linear-gradient(180deg, #e08a3e, #8c4a1f);
        box-shadow:1px 0 3px rgba(140,74,31,0.3);
    }
    .news-item h3{
        font-family:'Mukta',sans-serif;
        font-size:23px;
        font-weight:900;
        color:#1f1d18;
        margin-bottom:12px;
        padding-left:6px;
    }
    .news-list{
        list-style:none;
        padding-left:6px;
        line-height:1.75;
        font-size:18px;
    }
    .news-list li{ margin-bottom:8px; position:relative; padding-left:22px; }
    .news-list li::before{
        content:"◆";
        position:absolute; left:0; top:2px;
        font-size:9px; color:#d9772a;
    }
    .news-list b{ color:#b85c1a; }

    /* ---------- Q&A ---------- */
    .question{
        position:relative; z-index:5;
        background:linear-gradient(180deg,#ffffff,#fffdf7);
        padding:22px 30px;
        margin-bottom:22px;
        border-radius:14px;
        box-shadow:
            0 12px 26px rgba(0,0,0,0.10),
            inset 0 1px 0 rgba(255,255,255,0.9);
        border:1.5px solid #ecdcb5;
    }
    .q-number{
        display:inline-flex; align-items:center; justify-content:center;
        width:46px; height:46px;
        background:radial-gradient(circle at 35% 30%, #f0a05a, #b85c1a 75%);
        color:#fff;
        font-family:'Poppins',sans-serif; font-weight:900; font-size:19px;
        border-radius:50%;
        margin-bottom:12px;
        box-shadow:
            0 6px 14px rgba(184,92,26,0.4),
            inset 0 1px 2px rgba(255,255,255,0.5),
            inset 0 -3px 4px rgba(120,50,10,0.4);
    }
    .q-text{
        font-size:18px; font-weight:700; color:#241f18;
        margin-bottom:12px; line-height:1.55;
    }
    .a-pill{
        display:inline-block;
        background:linear-gradient(180deg,#fbf1dc,#f3e2bd);
        border-radius:8px;
        padding:9px 18px;
        font-size:16px; font-weight:600; color:#3a352b;
        box-shadow:0 3px 8px rgba(140,74,31,0.15), inset 0 1px 0 rgba(255,255,255,0.7);
    }
    .a-pill b{ color:#a63d2c; }

    /* ---------- Footer ribbon ---------- */
    .footer{
        position:relative; z-index:5;
        margin-top:auto;
        padding-top:26px;
        text-align:center;
    }
    .footer .plate{
        display:inline-block;
        padding:12px 34px;
        border-radius:30px;
        background:linear-gradient(180deg,#26456a,#1c3552);
        box-shadow:0 8px 20px rgba(28,53,82,0.4), inset 0 1px 1px rgba(255,255,255,0.15);
        font-family:'Mukta',sans-serif;
        font-weight:900;
        font-size:17px;
        letter-spacing:1.5px;
        color:#f0c66a;
    }

    @media print{
        body{ background:#fff; }
        .editor{ display:none; }
        .preview-wrap{ padding:0; height:auto; overflow:visible; align-items:flex-start; }
        .page-frame{ box-shadow:none; }
        @page{ size:A4; margin:0; }
    }
</style>
</head>
<body>

<div class="editor">
    <h1>📋 News Bulletin Generator</h1>
    <div class="sub">Plain text daalo → design apne aap ban jayega</div>

    <label>Subtitle (top strip)</label>
    <input type="text" id="subtitleInput" value="JUNE 2026 • PART - 2">

    <label>Footer text</label>
    <input type="text" id="footerInput" value="KULDEEP BISHNOI • RAS PRE + MAINS PREPARATION">

    <label>News / Questions text</label>
    <textarea id="rawInput">SECTION: महत्वपूर्ण समाचार बुलेट्स

NEWS: राजस्थान सौर ऊर्जा नीति 2026
- **30 GW** उत्पादन लक्ष्य निर्धारित
- **5000 करोड़** रुपये का निवेश प्रस्तावित
- किसानों को **60% सब्सिडी** दी जाएगी

NEWS: राष्ट्रीय आर्थिक अपडेट
- GDP वृद्धि दर **7.2%** दर्ज की गई
- FDI (विदेशी निवेश) में **18%** की बढ़ोतरी
- नई MSME नीति जारी

NEWS: राजस्थान बजट 2026-27 मुख्य घोषणाएँ
- शिक्षा क्षेत्र में **18%** बढ़ोतरी
- महिला सशक्तिकरण के लिए नई योजनाएँ
- सौर ऊर्जा पर विशेष फोकस

SECTION: प्रैक्टिस प्रश्न

Q: राजस्थान सरकार की नई सौर नीति का लक्ष्य क्या है?
A: 30 GW सौर ऊर्जा उत्पादन

Q: वर्तमान में भारत का GDP वृद्धि दर कितना है?
A: 7.2%</textarea>

    <div class="help">
        <b>Format:</b><br>
        <b>SECTION:</b> नया heading<br>
        <b>NEWS:</b> नया news card<br>
        <b>-</b> bullet point<br>
        <b>Q:</b> / <b>A:</b> question-answer<br>
        <b>**text**</b> = highlight<br><br>
        Content kam ho to text/spacing bada karke page bhar dega, zyada ho to chhota karke fit karega — page hamesha bhara dikhega.
    </div>

    <div class="warn">
        ⚠️ Print/PDF karte waqt <b>Paper size</b> dropdown mein manually <b>A4</b> select kar lena — kai Android print dialog default "Letter" rakhte hain jo apne aap change nahi hota.
    </div>

    <div class="zoom-status" id="zoomStatus"></div>

    <div class="btn-row">
        <button class="btn primary" onclick="window.print()">🖨️ Print / Save PDF</button>
        <button class="btn secondary" onclick="downloadHTML()">⬇️ Download HTML</button>
    </div>
</div>

<div class="preview-wrap">
    <div class="page-frame" id="pageFrame">
        <svg style="position:absolute;width:0;height:0">
            <defs>
                <linearGradient id="brassGrad" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#f2c07a"/>
                    <stop offset="55%" stop-color="#d9772a"/>
                    <stop offset="100%" stop-color="#8c4a1f"/>
                </linearGradient>
            </defs>
        </svg>

        <svg class="corner tl" viewBox="0 0 70 70">
            <path d="M4 66 V26 Q4 4 26 4 H66" fill="none" stroke="url(#brassGrad)" stroke-width="5" stroke-linecap="round"/>
            <circle cx="20" cy="20" r="4.5" fill="url(#brassGrad)"/>
        </svg>
        <svg class="corner tr" viewBox="0 0 70 70">
            <path d="M4 66 V26 Q4 4 26 4 H66" fill="none" stroke="url(#brassGrad)" stroke-width="5" stroke-linecap="round"/>
            <circle cx="20" cy="20" r="4.5" fill="url(#brassGrad)"/>
        </svg>
        <svg class="corner bl" viewBox="0 0 70 70">
            <path d="M4 66 V26 Q4 4 26 4 H66" fill="none" stroke="url(#brassGrad)" stroke-width="5" stroke-linecap="round"/>
            <circle cx="20" cy="20" r="4.5" fill="url(#brassGrad)"/>
        </svg>
        <svg class="corner br" viewBox="0 0 70 70">
            <path d="M4 66 V26 Q4 4 26 4 H66" fill="none" stroke="url(#brassGrad)" stroke-width="5" stroke-linecap="round"/>
            <circle cx="20" cy="20" r="4.5" fill="url(#brassGrad)"/>
        </svg>

        <div class="page" id="page">
            <div class="header">
                <div class="main-title">समसामयिकी</div>
                <div class="subtitle" id="subtitleOut">JUNE 2026 • PART - 2</div>
                <div class="header-rule"><div class="bar"></div><div class="seal"></div><div class="bar"></div></div>
            </div>

            <div id="bodyOut"></div>

            <div class="footer">
                <div class="plate" id="footerOut">KULDEEP BISHNOI • RAS PRE + MAINS PREPARATION</div>
            </div>
        </div>
    </div>
</div>

<script>
function escapeHTML(str){
    return str.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
}
function inlineBold(str){
    return escapeHTML(str).replace(/\*\*(.+?)\*\*/g, "<b>$1</b>");
}

function buildHTML(){
    const raw = document.getElementById('rawInput').value;
    const lines = raw.split('\n');

    let html = '';
    let qNum = 0;
    let newsOpen = false;
    let qOpen = false;

    function closeNews(){ if(newsOpen){ html += `</ul></div>`; newsOpen = false; } }
    function closeQuestion(){ if(qOpen){ html += `</div>`; qOpen = false; } }

    lines.forEach(line=>{
        const t = line.trim();
        if(t === '') return;

        if(t.startsWith('SECTION:')){
            closeNews(); closeQuestion();
            html += `<div class="section-title">${escapeHTML(t.replace('SECTION:','').trim())}</div>`;
        }
        else if(t.startsWith('NEWS:')){
            closeNews(); closeQuestion();
            html += `<div class="news-item"><h3>${escapeHTML(t.replace('NEWS:','').trim())}</h3><ul class="news-list">`;
            newsOpen = true;
        }
        else if(t.startsWith('-')){
            html += `<li>${inlineBold(t.replace(/^-/, '').trim())}</li>`;
        }
        else if(t.startsWith('Q:')){
            closeNews(); closeQuestion();
            qNum++;
            html += `<div class="question"><div class="q-number">${String(qNum).padStart(2,'0')}</div><p class="q-text">${inlineBold(t.replace('Q:','').trim())}</p>`;
            qOpen = true;
        }
        else if(t.startsWith('A:')){
            html += `<div class="a-pill"><b>उत्तर:</b> ${inlineBold(t.replace('A:','').trim())}</div>`;
        }
    });
    closeNews(); closeQuestion();
    return html;
}

/* Bidirectional fit: shrink if overflowing, GROW if under-filled — page always looks full */
function fitToOnePage(){
    const page = document.getElementById('page');
    const frame = document.getElementById('pageFrame');
    const status = document.getElementById('zoomStatus');

    page.style.zoom = 1;
    const natural = page.scrollHeight;
    const available = frame.clientHeight;

    let zoom = available / natural;
    zoom = Math.max(0.55, Math.min(zoom, 1.35));
    page.style.zoom = zoom;

    for(let i=0;i<4;i++){
        const h = page.scrollHeight;
        if (h > available && zoom > 0.55) { zoom -= 0.02; page.style.zoom = zoom; }
        else if (h < available*0.95 && zoom < 1.35) { zoom += 0.02; page.style.zoom = zoom; }
        else break;
    }

    if (zoom >= 1.34) status.textContent = `Content kam hai — text ${Math.round(zoom*100)}% tak bada kiya, फिर भी niche halki jagah bach sakti hai`;
    else if (zoom > 1.02) status.textContent = `Auto-fill: page bharne ke liye text ${Math.round(zoom*100)}% size par set hua`;
    else if (zoom < 0.98) status.textContent = `Auto-fit: text ${Math.round(zoom*100)}% size par chhota kiya`;
    else status.textContent = `✅ Perfect fit`;
}

function render(){
    document.getElementById('bodyOut').innerHTML = buildHTML();
    document.getElementById('subtitleOut').textContent = document.getElementById('subtitleInput').value;
    document.getElementById('footerOut').textContent = document.getElementById('footerInput').value;
    requestAnimationFrame(fitToOnePage);
}

function downloadHTML(){
    const pageHTML = document.getElementById('pageFrame').outerHTML;
    const styles = document.querySelector('style').outerHTML;
    const doc = `<!DOCTYPE html><html lang="hi"><head><meta charset="UTF-8"><title>समसामयिकी</title>${styles}
    <style>body{background:#eee6d4;display:flex;justify-content:center;padding:40px 20px;}</style>
    </head><body>${pageHTML}</body></html>`;
    const blob = new Blob([doc], {type:'text/html'});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = 'current-affairs.html';
    a.click();
    URL.revokeObjectURL(url);
}

document.getElementById('rawInput').addEventListener('input', render);
document.getElementById('subtitleInput').addEventListener('input', render);
document.getElementById('footerInput').addEventListener('input', render);
window.addEventListener('resize', fitToOnePage);
render();
</script>

</body>
</html>
